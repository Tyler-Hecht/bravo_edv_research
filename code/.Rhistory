model.ranef$cond[1:10]
model.ranef$cond$region[1]
model.ranef$cond$region[:,1]
model.ranef$cond$region[1:2]
model.ranef$cond$region[1]
model.ranef$cond$region[:]
model.ranef$cond$region
model.ranef$cond$region$`(Intercept)`
dotplot(1:10, model.ranef)
dotplot(model.ranef)
dotplot(model.ranef$cond)
model.ranef$cond$region$`(Intercept)`
dotplot(model.ranef$cond)
